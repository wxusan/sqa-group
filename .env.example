DATABASE_URL="postgresql://user:password@127.0.0.1:5432/sqa"
AUTH_SECRET="replace-with-openssl-rand-base64-32"
AUTH_TRUST_HOST=true
ADMIN_EMAIL=""
ADMIN_PASSWORD=""
# Created automatically when a Vercel Blob store is connected to the project.
# Never commit the real value.
BLOB_READ_WRITE_TOKEN=""
# Required for delivery of website applications and complaints. Set a verified
# sender address in Resend before enabling this in production.
RESEND_API_KEY=""
RESEND_FROM="SQA Group <noreply@sqa.uz>"
COMPANY_RECEIVER_EMAIL="info@sqa.uz"
# Set only for local browser tests that deliberately exercise the local adapter.
# MEDIA_STORAGE="local"
