generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Staff {
  id           String             @id @default(cuid())
  slug         String             @unique
  photoUrl     String?
  department   String // certification | laboratory | management
  order        Int                @default(0)
  published    Boolean            @default(false)
  email        String?
  phone        String?
  linkedin     String?
  translations StaffTranslation[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([published, department, order])
}

model StaffTranslation {
  id        String  @id @default(cuid())
  staffId   String
  locale    String // uz | ru | en
  name      String
  position  String
  intro     String?
  bio       String?
  expertise String?
  staff     Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, locale])
}

model News {
  id           String            @id @default(cuid())
  slug         String            @unique
  imageUrl     String?
  publishedAt  DateTime?
  status       String            @default("draft") // draft | published
  featured     Boolean           @default(false)
  translations NewsTranslation[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([status, publishedAt])
}

model NewsTranslation {
  id      String  @id @default(cuid())
  newsId  String
  locale  String
  title   String
  summary String?
  body    String
  news    News    @relation(fields: [newsId], references: [id], onDelete: Cascade)

  @@unique([newsId, locale])
}

model Partner {
  id           String               @id @default(cuid())
  logoUrl      String
  websiteUrl   String?
  order        Int                  @default(0)
  published    Boolean              @default(false)
  translations PartnerTranslation[]
  createdAt    DateTime             @default(now())

  @@index([published, order])
}

model PartnerTranslation {
  id        String  @id @default(cuid())
  partnerId String
  locale    String
  name      String
  partner   Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@unique([partnerId, locale])
}

model AdminUser {
  id           String  @id @default(cuid())
  email        String  @unique
  passwordHash String
  name         String?
}

model Lead {
  id          String   @id @default(cuid())
  name        String
  phone       String
  email       String?
  company     String?
  serviceType String // certification | testing | surveillance | other
  message     String
  status      String   @default("new") // new | processed
  locale      String   @default("uz")
  createdAt   DateTime @default(now())

  @@index([status, createdAt])
}

/**
 * Per-page visibility toggle controlled from the admin panel.
 * A missing row means the page is enabled (default on).
 */
model PageSetting {
  key       String   @id
  enabled   Boolean  @default(true)
  updatedAt DateTime @updatedAt
}
